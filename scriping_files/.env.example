# ── Server ─────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://admin:secret@mongo:27017/scraper?authSource=admin
MONGO_USER=admin
MONGO_PASSWORD=secret
MONGO_DB=scraper
MONGO_PORT=27017

# ── Proxy ──────────────────────────────────────────────────────────────────────
PROXY_URL=http://your-proxy-host:port
PROXY_USERNAME=your_username
PROXY_PASSWORD=your_password
PROXY_CHECK_URL=https://ip.oxylabs.io/location

# ── Paths ──────────────────────────────────────────────────────────────────────
USER_DATA_DIR=./.playwright-profile
OUTPUT_DIR=./output
COOKIE_FILE=./output/cookies/1688-cookies.json

# ── Timeouts (ms) ──────────────────────────────────────────────────────────────
NAVIGATION_TIMEOUT_MS=120000
BODY_WAIT_TIMEOUT_MS=30000
VERIFICATION_CHECK_DELAY_MS=1000
NAVIGATION_RETRIES=1

# ── Feature flags ──────────────────────────────────────────────────────────────
CHECK_PROXY_FIRST=true
CHECK_PRODUCT_EXISTS=true
LOAD_1688_COOKIES=false
LOAD_SAVED_COOKIES=true
SAVE_PAGE_COOKIES=true
KEEP_BROWSER_OPEN=false
FRESH_BROWSER_PROFILE=false
BLOCK_PAGE_REDIRECTS=true
BLOCK_HEAVY_RESOURCES=true
